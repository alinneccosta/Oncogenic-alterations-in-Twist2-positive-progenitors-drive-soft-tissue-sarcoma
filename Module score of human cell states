cat("\n=== STEP 6B: EXTRACT SEURAT MODULE SCORES PER CLUSTER ===\n")

# Extract Seurat module scores for each cluster
seurat_module_results <- data.frame()

for(cell_type in valid_cell_types) {
  score_column <- paste0(cell_type, "_Patel_Score1")
  
  if(score_column %in% colnames(tumor@meta.data)) {
    cat("Extracting Seurat scores for", cell_type, "...\n")
    
    # Calculate average Seurat module score per cluster
    cluster_seurat_scores <- aggregate(tumor@meta.data[[score_column]], 
                                       by = list(cluster = tumor@meta.data$seurat_clusters), 
                                       FUN = mean, na.rm = TRUE)
    
    # Create data frame
    seurat_results <- data.frame(
      CellType = cell_type,
      Cluster = cluster_seurat_scores$cluster,
      SeuratModuleScore = cluster_seurat_scores$x,
      stringsAsFactors = FALSE
    )
    
    seurat_module_results <- rbind(seurat_module_results, seurat_results)
    cat("  ✓ Added", nrow(seurat_results), "entries\n")
  } else {
    cat("  ✗ Score column", score_column, "not found\n")
  }
}

