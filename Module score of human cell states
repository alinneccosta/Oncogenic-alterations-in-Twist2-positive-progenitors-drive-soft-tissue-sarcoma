        if(nrow(matching_row) > 0) {
          cluster_summary[[col_name]][i] <- matching_row$SeuratModuleScore[1]
        }
      }
    }
  }
}

print(cluster_summary)
write.csv(cluster_summary, file.path(results_dir, "cluster_summary_scores.csv"), row.names = FALSE)




