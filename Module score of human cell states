# Process each cell type
for(cell_type in cell_types) {
  cat("Processing", cell_type, "...\n")
  
  # Get human genes from the column
  type_genes <- as.character(patel_markers[[cell_type]])
  type_genes <- type_genes[!is.na(type_genes) & type_genes != ""]
  
  if(length(type_genes) == 0) {
    cat("  ✗ No genes found, skipping\n")
    next
  }
  
  # Convert to mouse
  mouse_genes <- convertHumanGeneList(type_genes)
  
  # Check availability in tumor data
  available_genes <- intersect(mouse_genes, rownames(tumor))
  patel_mouse_markers[[cell_type]] <- available_genes
  
  # Calculate rates
  conversion_rate <- round(length(mouse_genes) / length(type_genes) * 100, 1)
  availability_rate <- round(length(available_genes) / length(mouse_genes) * 100, 1)
  
  # Add to summary
  conversion_summary <- rbind(conversion_summary, data.frame(
    CellType = cell_type,
    Human_Genes = length(type_genes),
    Mouse_Genes = length(mouse_genes),
    Available_Genes = length(available_genes),
    Conversion_Rate = conversion_rate,
    Availability_Rate = availability_rate
  ))
  
  cat("  Human:", length(type_genes), "-> Mouse:", length(mouse_genes), 
      "-> Available:", length(available_genes), "\n")
}

