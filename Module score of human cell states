# Merge both scoring methods
cluster_summary <- merge(cluster_summary, seurat_summary, by = "Cluster", all = TRUE)

# Fill in missing values for custom scores
available_cell_types_in_results <- unique(module_results$CellType)
for(cell_type in c("mesoderm", "myoblast", "myocyte")) {
  if(cell_type %in% available_cell_types_in_results) {
    cell_type_data <- module_results[module_results$CellType == cell_type, ]
    col_name <- paste0(stringr::str_to_title(cell_type), "_Score_Custom")
    if(col_name %in% colnames(cluster_summary)) {
      for(i in 1:nrow(cluster_summary)) {
        cluster_num <- cluster_summary$Cluster_num[i]
        matching_row <- cell_type_data[cell_type_data$Cluster_num == cluster_num, ]
        if(nrow(matching_row) > 0) {
          cluster_summary[[col_name]][i] <- matching_row$ModuleScore[1]
        }
      }
    }
  }
}

# Fill in missing values for Seurat scores
available_cell_types_seurat <- unique(seurat_module_results$CellType)
for(cell_type in c("mesoderm", "myoblast", "myocyte")) {
  if(cell_type %in% available_cell_types_seurat) {
