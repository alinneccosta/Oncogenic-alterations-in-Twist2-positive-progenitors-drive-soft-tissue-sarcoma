  mesoderm = "#E31A1C",      # Bright red
  myoblast = "#1F78B4",      # Bright blue  
  myocyte = "#33A02C"        # Bright green
)

# Add colors for any other cell types found using a distinct palette
extra_types <- setdiff(valid_cell_types, names(cell_type_colors))
if(length(extra_types) > 0) {
  # Use ColorBrewer Set1 palette for additional colors
  extra_colors <- RColorBrewer::brewer.pal(min(9, max(3, length(extra_types))), "Set1")[1:length(extra_types)]
  names(extra_colors) <- extra_types
  cell_type_colors <- c(cell_type_colors, extra_colors)
  cat("Added colors for extra cell types:", paste(extra_types, collapse = ", "), "\n")
}

# Process each valid cell type
for(cell_type in valid_cell_types) {
  available_genes <- patel_mouse_markers[[cell_type]]
  cat("Processing", cell_type, "with", length(available_genes), "genes\n")
  
  # Calculate average expression per cluster using RNA assay
  avg_expr <- AverageExpression(tumor, features = available_genes, 
                                group.by = "combined_subclusters", assays = "RNA", slot = "data")
  expr_matrix <- as.matrix(avg_expr$RNA)
  cluster_scores <- colMeans(expr_matrix, na.rm = TRUE)
  
  # Normalize and log transform
  min_score <- min(cluster_scores, na.rm = TRUE)
  normalized_scores <- (cluster_scores - min_score) + 1
  log_scores <- log10(normalized_scores)
  
  # Store results
  type_results <- data.frame(
    CellType = cell_type,
    Cluster = names(cluster_scores),
    ModuleScore = log_scores,
    RawScore = cluster_scores,
    NormalizedExpression = cluster_scores,
    stringsAsFactors = FALSE
  )
  
  module_results <- rbind(module_results, type_results)
  cat("  ✓ Added", nrow(type_results), "entries\n")
}

